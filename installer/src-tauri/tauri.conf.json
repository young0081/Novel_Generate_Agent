{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NovelGenerateAgentSetup",
  "version": "0.2.0",
  "identifier": "com.novelgenerateagent.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "墨 · 创作 — 安装",
        "width": 760,
        "height": 520,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#efe8da",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
