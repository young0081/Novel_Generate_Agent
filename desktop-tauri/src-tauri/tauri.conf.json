{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NovelGenerateAgent",
  "version": "0.3.0",
  "identifier": "com.novelgenerateagent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "墨 · 创作",
        "width": 1240,
        "height": 820,
        "minWidth": 940,
        "minHeight": 640,
        "decorations": false,
        "backgroundColor": "#efe8da",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
